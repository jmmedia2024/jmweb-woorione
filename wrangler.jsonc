{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "woorione-hyperdrive-api",
  "main": "src/index.ts",
  "compatibility_date": "2025-02-04",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "hyperdrive": [
    {
      "binding": "HYPERDRIVE",
      "id": "your-hyperdrive-id-here",
      "localConnectionString": "postgres://user:password@localhost:5432/woorione"
    }
  ]
}
